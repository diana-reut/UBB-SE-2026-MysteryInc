<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="HospitalManagement.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HospitalManagement"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:HospitalManagement.Converters"
    mc:Ignorable="d"
    Title="MysteryInc Hospital Management">


    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="Transparent">
        <Grid.Resources>
            <SolidColorBrush x:Key="BrandDark" Color="#1E2A38"/>
            <SolidColorBrush x:Key="BrandPrimary" Color="#2A6478"/>
            <SolidColorBrush x:Key="BrandSecondary" Color="#4A90A4"/>
            <SolidColorBrush x:Key="BrandAccent" Color="#5EC499"/>
            <SolidColorBrush x:Key="GhostAccent" Color="#FFE779"/>

            <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>

            <Style x:Key="AnimatedRoleButtonStyle" TargetType="Button">
                <Setter Property="RenderTransformOrigin" Value="0.5, 0.5"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="RootGrid" Background="Transparent">
                                <Border x:Name="ContentBorder" 
                                        Background="{TemplateBinding Background}" 
                                        CornerRadius="{TemplateBinding CornerRadius}" 
                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="ScaleT" ScaleX="1" ScaleY="1" />
                                    </Border.RenderTransform>

                                    <ContentPresenter x:Name="ContentPresenter" 
                                                      Content="{TemplateBinding Content}" 
                                                      ContentTemplate="{TemplateBinding ContentTemplate}" 
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" 
                                                      Padding="{TemplateBinding Padding}"/>
                                </Border>

                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal">
                                            <Storyboard>
                                                <DoubleAnimation To="1" Duration="0:0:0.1" Storyboard.TargetName="ScaleT" Storyboard.TargetProperty="ScaleX" />
                                                <DoubleAnimation To="1" Duration="0:0:0.1" Storyboard.TargetName="ScaleT" Storyboard.TargetProperty="ScaleY" />
                                                <DoubleAnimation To="1.0" Duration="0:0:0.1" Storyboard.TargetName="ContentBorder" Storyboard.TargetProperty="Opacity" />
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <DoubleAnimation To="1.02" Duration="0:0:0.1" Storyboard.TargetName="ScaleT" Storyboard.TargetProperty="ScaleX" />
                                                <DoubleAnimation To="1.02" Duration="0:0:0.1" Storyboard.TargetName="ScaleT" Storyboard.TargetProperty="ScaleY" />
                                                <DoubleAnimation To="0.85" Duration="0:0:0.1" Storyboard.TargetName="ContentBorder" Storyboard.TargetProperty="Opacity" />
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <DoubleAnimation To="0.97" Duration="0:0:0.05" Storyboard.TargetName="ScaleT" Storyboard.TargetProperty="ScaleX" />
                                                <DoubleAnimation To="0.97" Duration="0:0:0.05" Storyboard.TargetName="ScaleT" Storyboard.TargetProperty="ScaleY" />
                                                <DoubleAnimation To="0.75" Duration="0:0:0.05" Storyboard.TargetName="ContentBorder" Storyboard.TargetProperty="Opacity" />
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            
            
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{StaticResource BrandDark}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" Source="ms-appx:///Assets/hospitalLogo.png" 
                   Height="45" Width="45" Margin="20,0,15,0" 
                   VerticalAlignment="Center"/>

            <TextBlock Grid.Column="1" Text="COOLSVILLE GENERAL HOSPITAL" 
                       VerticalAlignment="Center" Foreground="White" 
                       FontSize="22" FontWeight="SemiBold" 
                       CharacterSpacing="50"/>
        </Grid>

        <Grid Grid.Row="1" Padding="40" Background="#F4F6F8">
            <Border Background="White" CornerRadius="12" MaxWidth="500" 
                    VerticalAlignment="Center" HorizontalAlignment="Center" 
                    Padding="45,50" 
                    BorderBrush="#E5E7EB" BorderThickness="1">

                <StackPanel>
                    <TextBlock Text="Welcome Back" 
                               FontSize="28" Foreground="{StaticResource BrandDark}" 
                               FontWeight="Bold" HorizontalAlignment="Center" 
                               Margin="0,0,0,5"/>
                    <TextBlock Text="Please log in by selecting your role below" 
                               FontSize="14" Foreground="#6B7280" 
                               HorizontalAlignment="Center" Margin="0,0,0,35"/>

                    <Button Style="{StaticResource AnimatedRoleButtonStyle}"
                            Command="{Binding RedirectToAdminRoleCommand}" 
                            Background="{StaticResource BrandPrimary}" Foreground="White" 
                            Margin="0,8" Height="55" Width="300" 
                            CornerRadius="6" HorizontalAlignment="Center"
                            HorizontalContentAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <FontIcon Glyph="&#xE7EF;" Margin="0,0,10,0"/>
                            <TextBlock Text="ADMINISTRATOR" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource AnimatedRoleButtonStyle}"
                            Command="{Binding RedirectToStaffRoleCommand}" 
                            Background="{StaticResource BrandSecondary}" Foreground="White" 
                            Margin="0,8" Height="55" Width="300" 
                            CornerRadius="6" HorizontalAlignment="Center"
                            HorizontalContentAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <FontIcon Glyph="&#xE1D0;" Margin="0,0,10,0"/>
                            <TextBlock Text="MEDICAL STAFF" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource AnimatedRoleButtonStyle}"
                            Command="{Binding RedirectToPharmacistRoleCommand}" 
                            Background="{StaticResource BrandAccent}" Foreground="White" 
                            Margin="0,8" Height="55" Width="300" 
                            CornerRadius="6" HorizontalAlignment="Center"
                            HorizontalContentAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <FontIcon Glyph="&#xE8D5;" Margin="0,0,10,0"/>
                            <TextBlock Text="PHARMACIST" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Button Style="{StaticResource AnimatedRoleButtonStyle}"
                    Command="{Binding GhostSightingCommand}"
                    HorizontalAlignment="Left" VerticalAlignment="Bottom" 
                    Background="Transparent" BorderBrush="Transparent"
                    Padding="10" ToolTipService.ToolTip="Report Paranormal Activity">
                <Border Background="{StaticResource GhostAccent}" CornerRadius="20" Padding="15,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Spotted a ghost?" Foreground="{StaticResource BrandDark}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Button>
        </Grid>

        <Grid Grid.Row="0" Grid.RowSpan="2"
              Background="#F0000000"
              IsHitTestVisible="True"
              Visibility="{Binding IsExorcismAlertVisible, Converter={StaticResource BoolToVis}}">
            <Border MaxWidth="600" CornerRadius="16"
            Background="#1A0000" BorderBrush="#CC0000" BorderThickness="3"
            Padding="48,40" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Spacing="20" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE7BA;" FontSize="72" Foreground="#FF3333" HorizontalAlignment="Center"/>
                    <TextBlock Text="CRITICAL PARANORMAL ACTIVITY DETECTED"
                       Foreground="#FF3333" FontSize="20" FontWeight="Bold"
                       TextAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock Text="Multiple sightings confirmed. Please CALL THE PRIEST immediately."
                       Foreground="White" FontSize="16"
                       TextAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
