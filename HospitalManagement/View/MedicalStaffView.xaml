<Window
    x:Class="HospitalManagement.View.MedicalStaffView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HospitalManagement.View"
    xmlns:vm="using:HospitalManagement.ViewModel"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:entity="using:HospitalManagement.Entity"
    xmlns:converters="using:HospitalManagement.Converters"
    mc:Ignorable="d"
    Title="Medical Staff Dashboard">

    <Grid Padding="24" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.Resources>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    Spacing="12" 
                    Margin="0,0,0,24">

            <TextBox x:Name="SearchTextBox" 
                     PlaceholderText="Search patients by name or CNP..." 
                     Width="400" 
                     Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <Button Content="Go" 
                    Command="{x:Bind ViewModel.SearchCommand}" 
                    Style="{StaticResource AccentButtonStyle}" 
                    Width="80"/>
        </StackPanel>

        <Grid Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                       Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" 
                       Foreground="#D13438" 
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,16" />

            <ListView Grid.Row="1" Grid.Column="0"
                      ItemsSource="{Binding SearchResults}"
                      SelectedItem="{Binding SelectedPatient, Mode=TwoWay}"
                      DoubleTapped="PatientList_DoubleTapped" 
                      SelectionMode="Single">

                <ListView.Header>
                    <Grid Padding="12,8" Background="{ThemeResource LayerFillColorAltBrush}" CornerRadius="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="First Name" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="Last Name" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Grid.Column="2" Text="CNP" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Grid.Column="3" Text="Date of Birth" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                </ListView.Header>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="entity:Patient">
                        <Grid Padding="12,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind FirstName}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{x:Bind LastName}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{x:Bind Cnp}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{x:Bind Dob.ToString()}" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel Grid.Row="1" Grid.Column="1" Margin="20,0,0,0" Width="240" Spacing="15" VerticalAlignment="Top"
                        Visibility="{Binding SelectedPatient, Converter={StaticResource NullToVisibilityConverter}}">

                <TextBlock Text="Patient Actions" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10"/>

                <Button Content="Compatible Blood Donors" 
                        Command="{Binding FindBloodDonorsCommand}" 
                        HorizontalAlignment="Stretch" 
                        Style="{StaticResource AccentButtonStyle}"/>

                <Button Content="Request Organ Transplant" 
                        Command="{Binding RequestTransplantCommand}" 
                        HorizontalAlignment="Stretch" 
                        Style="{StaticResource AccentButtonStyle}"/>

            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Left" 
                    Spacing="12" 
                    Margin="0,24,0,0">

            <Button Content="Back to Main" 
                    Command="{x:Bind ViewModel.BackToMainCommand}" />

            <Button Content="I saw a ghost" 
                    Command="{x:Bind ViewModel.GhostSightingCommand}" 
                    Background="DarkRed" 
                    Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>