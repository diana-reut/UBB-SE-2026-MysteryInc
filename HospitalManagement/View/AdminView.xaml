<Window
    x:Class="HospitalManagement.View.AdminView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:entity="using:HospitalManagement.Entity"
    xmlns:converters="using:HospitalManagement.Converters"
    Title="Admin Dashboard - Hospital Management" >

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <converters:DateToStringConverter x:Key="DateToStringConverter"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1F2A37" Padding="20">
            <StackPanel Spacing="15">
                <TextBlock Text="HOSPITAL" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>

                <Button Content="Home" Command="{Binding NavigateToHomeCommand}" Height="40" HorizontalAlignment="Stretch" CornerRadius="8"/>

                <Button Click="OpenPage_Click" Height="40" HorizontalAlignment="Stretch" CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="FourBars"/>
                        <TextBlock Text="Statistics"/>
                    </StackPanel>
                </Button>

                <Border Height="1" Background="#3A4758" Margin="0,20,0,20"/>
                <TextBlock Text="Quick Info" FontSize="16" Foreground="LightGray" Margin="0,10,0,0"/>

                <Border Background="#2C3A4A" CornerRadius="8" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Patients" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="{Binding Patients.Count}" Foreground="White"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="#2C3A4A" Padding="15" CornerRadius="10" Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal" Spacing="15">
                    <TextBox PlaceholderText="Search by Name or CNP..." Width="250"
                             Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <Button Content="Add New Patient" Click="OpenAddPatientDialog" CornerRadius="6"/>

                    <Button Content="I saw a ghost!" Command="{Binding GhostSightingCommand}"
                            Background="#FFE779" Foreground="#1E2A38" FontWeight="Bold" CornerRadius="4" Padding="12,8"/>

                    <Button Content="" FontFamily="Segoe MDL2 Assets" Background="Transparent" VerticalAlignment="Center">
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedRight">
                                <StackPanel Width="220" Spacing="10" Padding="10">
                                    <TextBlock Text="Advanced Filters" FontWeight="Bold" Margin="0,0,0,5"/>
                                    <NumberBox Header="Min Age" Value="{Binding MinAge, Mode=TwoWay}" SpinButtonPlacementMode="Compact" />
                                    <NumberBox Header="Max Age" Value="{Binding MaxAge, Mode=TwoWay}" SpinButtonPlacementMode="Compact" />
                                    <ComboBox Header="Sex" HorizontalAlignment="Stretch" SelectedItem="{Binding SelectedSexFilter, Mode=TwoWay}">
                                        <ComboBoxItem Content="M"/>
                                        <ComboBoxItem Content="F"/>
                                    </ComboBox>
                                    <Rectangle Height="1" Fill="Gray" Margin="0,5"/>
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Content="Clear" Command="{Binding ClearFilterCommand}" HorizontalAlignment="Stretch" Grid.Column="0"/>
                                        <Button Content="Apply" Command="{Binding FilterPatientCommand}" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Grid.Column="1"/>
                                    </Grid>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>

            </Border>

            <Button Content="Assign Organ Donor" Command="{Binding OpenOrganDonorCommand}" Style="{StaticResource AccentButtonStyle}"/>

            <Button Command="{Binding ReportGhostCommand}"
                    Background="#FFE779" 
                    BorderBrush="Transparent"
                    Padding="10,8" 
                    CornerRadius="4"
                    ToolTipService.ToolTip="Report Paranormal Activity">

                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFD54F"/>
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#1E2A38"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#FFC107"/>
                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#1E2A38"/>
                </Button.Resources>

                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE7BA;" Margin="0,0,8,0" FontSize="14" Foreground="#1E2A38"/>
                            <TextBlock Text="I saw a ghost!" Foreground="#1E2A38" FontWeight="Bold"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
            <!--</StackPanel> -->

            <Border Grid.Row="1" Background="#F8FAFC" CornerRadius="10" Padding="10">
            <!--     <ListView ItemsSource="{Binding Patients}" SelectedItem="{Binding SelectedPatient, Mode=TwoWay}" SelectionMode="Single">
                    <ListView.Header>
