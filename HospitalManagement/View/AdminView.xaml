                <ListView Grid.Row="1" Grid.Column="0" 
              ItemsSource="{Binding Patients}" 
              SelectedItem="{Binding SelectedPatient, Mode=TwoWay}"
              SelectionMode="Single"
              Margin="0,10,0,0"
              Padding="10"
              BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}" 
              BorderThickness="1"
              CornerRadius="8">
                    <ListView.Header>
                        <Grid Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" 
                      Padding="12,8" CornerRadius="4" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="FIRST NAME" FontWeight="Bold" FontSize="12" Foreground="Gray" Grid.Column="0" Margin="10,0,0,0"/>
                            <TextBlock Text="LAST NAME" FontWeight="Bold" FontSize="12" Foreground="Gray" Grid.Column="1" Margin="10,0,0,0"/>
                            <TextBlock Text="SEX" FontWeight="Bold" FontSize="12" Foreground="Gray" Grid.Column="2" HorizontalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBlock Text="DOB" FontWeight="Bold" FontSize="11" Foreground="Gray" Grid.Column="3" Margin="40,0,0,0"/>
                            <TextBlock Text="CNP" FontWeight="Bold" FontSize="11" Foreground="Gray" Grid.Column="4" Margin="45,0,0,0"/>
                            <TextBlock Text="PHONE" FontWeight="Bold" FontSize="11" Foreground="Gray" Grid.Column="5" Margin="45,0,0,0"/>
                            <TextBlock Text="EMERGENCY" FontWeight="Bold" FontSize="11" Foreground="Gray" Grid.Column="6" Margin="30,0,0,0"/>
                        </Grid>
                    </ListView.Header>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="entity:Patient">
                            <Grid Padding="12,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding FirstName}" VerticalAlignment="Center" Grid.Column="0" Margin="10,0,0,0"/>
                                <TextBlock Text="{Binding LastName}" VerticalAlignment="Center" Grid.Column="1" Margin="10,0,0,0"/>
                                <TextBlock Text="{Binding Sex}" VerticalAlignment="Center" Grid.Column="2" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="10,0,0,0"/>
                                <TextBlock Text="{Binding Dob, Converter={StaticResource DateToStringConverter}}" VerticalAlignment="Center"  Grid.Column="3" Margin="10,0,0,0" />
                                <TextBlock Text="{Binding Cnp}" VerticalAlignment="Center" Grid.Column="4" FontSize="12" Margin="10,0,0,0"/>
                                <TextBlock Text="{Binding PhoneNo}" VerticalAlignment="Center" Grid.Column="5" Margin="10,0,0,0"/>
                                <TextBlock Text="{Binding EmergencyContact}" VerticalAlignment="Center" Grid.Column="6" FontStyle="Italic" Margin="10,0,0,0" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="BorderBrush" Value="{ThemeResource SystemControlBackgroundBaseLowBrush}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
                <!--<ScrollViewer Grid.Row="1" Grid.Column="1" Margin="20,0,0,0" Visibility="{Binding SelectedPatient, Converter={StaticResource NullToVisibilityConverter}}" /> -->
            </Border>
        </Grid>

        <Border Grid.Column="2" Background="#1F2A37" Padding="20" 
                Visibility="{Binding SelectedPatient, Converter={StaticResource NullToVisibilityConverter}}">

            <StackPanel Spacing="10">
                <TextBlock Text="Patient Details" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
                <TextBlock Text="Phone Number" Foreground="White"/>
                <TextBox Text="{Binding EditingPatient.PhoneNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Emergency Contact" Foreground="White"/>
                <TextBox Text="{Binding EditingPatient.EmergencyContact, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Content="Update Patient" Command="{Binding UpdatePatientCommand}" HorizontalAlignment="Stretch" Margin="0,15,0,0" CornerRadius="6"/>
                <Button Content="Archive Patient" Command="{Binding ArchivePatientCommand}" HorizontalAlignment="Stretch" Foreground="Red" CornerRadius="6"/>
                <Button Content="Mark as Deceased" Command="{Binding MarkAsDeceasedCommand}" HorizontalAlignment="Stretch" IsEnabled="{Binding IsNotDeceased}" CornerRadius="6"/>
            </StackPanel>
        </Border>

        <Grid Grid.ColumnSpan="3" Background="#F0000000" IsHitTestVisible="True" 
              Visibility="{Binding IsExorcismAlertVisible, Converter={StaticResource BoolToVis}}">
            <Border MaxWidth="600" CornerRadius="16" Background="#1A0000" BorderBrush="#CC0000" BorderThickness="3" Padding="48,40" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Spacing="20" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE7BA;" FontSize="72" Foreground="#CC0000" HorizontalAlignment="Center"/>
                    <TextBlock Text="CRITICAL PARANORMAL ACTIVITY DETECTED" Foreground="#FF3333" FontSize="20" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock Text="Multiple sightings confirmed. Please CALL THE PRIEST immediately." Foreground="White" FontSize="16" TextAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>