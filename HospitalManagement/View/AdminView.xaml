<Window
    x:Class="HospitalManagement.View.AdminView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:entity="using:HospitalManagement.Entity"
    xmlns:converters="using:HospitalManagement.Converters"
    Title="Admin Dashboard - Hospital Management" >

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <converters:DateToStringConverter x:Key="DateToStringConverter"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <converters:DeceasedToColorConverter x:Key="DeceasedToColor"/>
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1F2A37" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="15">
                    <TextBlock Text="HOSPITAL" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>
                    <Button Click="OpenPage_Click" Height="40" HorizontalAlignment="Stretch" CornerRadius="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="FourBars"/>
                            <TextBlock Text="Statistics"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding LoadArchivedPatientsCommand}" Click="OpenArchive_Click" Height="40" HorizontalAlignment="Stretch" CornerRadius="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            
                            <TextBlock Text="Archive"/>
                        </StackPanel>
                    </Button>
                    <Border Height="1" Background="#3A4758" Margin="0,20,0,20"/>
                    <TextBlock Text="Quick Info" FontSize="16" Foreground="LightGray" Margin="0,10,0,0"/>
                    <Border Background="#2C3A4A" CornerRadius="8" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Patients" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="{Binding Patients.Count}" Foreground="White"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="10">
                    <Border Height="1" Background="#3A4758" Margin="0,0,0,10"/>
                    <Button Command="{Binding NavigateToHomeCommand}" Height="40" HorizontalAlignment="Stretch" CornerRadius="8" Background="Transparent">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Home"/>
                            <TextBlock Text="Home"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.RowSpan="2" Visibility="{Binding IsActiveMode, Converter={StaticResource BoolToVis}}">
                <Border Background="#2C3A4A" Padding="15" CornerRadius="10" Margin="0,0,0,15">
                    <StackPanel Orientation="Horizontal" Spacing="15">
                        <TextBox PlaceholderText="Search by Name or CNP..." Width="250" Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="Add New Patient" Click="OpenAddPatientDialog" CornerRadius="6"/>
                        <Button Content="I saw a ghost!" Command="{Binding GhostSightingCommand}" Background="#FFE779" Foreground="#1E2A38" FontWeight="Bold" CornerRadius="4" Padding="12,8"/>
                    </StackPanel>
                </Border>

                <Border Background="#F8FAFC" CornerRadius="10" Padding="10" Height="600">
                    <ListView ItemsSource="{Binding Patients}" SelectedItem="{Binding SelectedPatient, Mode=TwoWay}" SelectionMode="Single" DoubleTapped="PatientListView_DoubleTapped">
                        <ListView.Header>
                            <Grid Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" Padding="12,8" CornerRadius="4" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="FIRST NAME" FontWeight="Bold" FontSize="12" Foreground="Gray" Grid.Column="0" Margin="10,0,0,0"/>
                                <TextBlock Text="LAST NAME" FontWeight="Bold" FontSize="12" Foreground="Gray" Grid.Column="1" Margin="10,0,0,0"/>
                                <TextBlock Text="SEX" FontWeight="Bold" FontSize="12" Foreground="Gray" Grid.Column="2" HorizontalAlignment="Center"/>
                                <TextBlock Text="DOB" FontWeight="Bold" FontSize="11" Foreground="Gray" Grid.Column="3" Margin="40,0,0,0"/>
                                <TextBlock Text="CNP" FontWeight="Bold" FontSize="11" Foreground="Gray" Grid.Column="4" Margin="45,0,0,0"/>
                                <TextBlock Text="PHONE" FontWeight="Bold" FontSize="11" Foreground="Gray" Grid.Column="5" Margin="45,0,0,0"/>
                                <TextBlock Text="EMERGENCY" FontWeight="Bold" FontSize="11" Foreground="Gray" Grid.Column="6" Margin="30,0,0,0"/>
                            </Grid>
                        </ListView.Header>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="entity:Patient">
                                <Grid Padding="12,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding FirstName}" Grid.Column="0" Foreground="Black" Margin="10,0,0,0"/>
                                    <TextBlock Text="{Binding LastName}" Grid.Column="1" Foreground="Black" Margin="10,0,0,0"/>
                                    <TextBlock Text="{Binding Sex}" Grid.Column="2" Foreground="Black" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Dob, Converter={StaticResource DateToStringConverter}}" Foreground="Black" Grid.Column="3" Margin="10,0,0,0" />
                                    <TextBlock Text="{Binding Cnp}" Grid.Column="4" Foreground="Black" FontSize="12" Margin="10,0,0,0"/>
                                    <TextBlock Text="{Binding PhoneNo}" Grid.Column="5" Foreground="Black" Margin="10,0,0,0"/>
                                    <TextBlock Text="{Binding EmergencyContact}" Grid.Column="6" Foreground="Black" FontStyle="Italic" Margin="10,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </StackPanel>

            <StackPanel Grid.RowSpan="2" Visibility="{Binding IsArchivedMode, Converter={StaticResource BoolToVis}}">
                <Button Content="← Back to Active Dashboard" Click="BackToActive_Click" Style="{StaticResource AccentButtonStyle}" Margin="0,0,0,15"/>
                <Border Background="#374151" Padding="15" CornerRadius="10" Margin="0,0,0,15">
                    <TextBlock Text="ARCHIVED PATIENT RECORDS" Foreground="White" FontWeight="Bold" FontSize="18"/>
                </Border>
                <Border Background="#F1F5F9" CornerRadius="10" Padding="10" Height="600">
                    <ListView ItemsSource="{Binding ArchivedPatients}" SelectedItem="{Binding SelectedPatient, Mode=TwoWay}">
                        <ListView.Header>
                            <Grid Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" Padding="12,8" CornerRadius="4" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="FIRST NAME" FontWeight="Bold" FontSize="12" Foreground="Gray" Grid.Column="0" Margin="10,0,0,0"/>
                                <TextBlock Text="LAST NAME" FontWeight="Bold" FontSize="12" Foreground="Gray" Grid.Column="1" Margin="10,0,0,0"/>
                                <TextBlock Text="SEX" FontWeight="Bold" FontSize="12" Foreground="Gray" Grid.Column="2" HorizontalAlignment="Center"/>
                                <TextBlock Text="DOB" FontWeight="Bold" FontSize="11" Foreground="Gray" Grid.Column="3" Margin="40,0,0,0"/>
                                <TextBlock Text="CNP" FontWeight="Bold" FontSize="11" Foreground="Gray" Grid.Column="4" Margin="45,0,0,0"/>
                                <TextBlock Text="PHONE" FontWeight="Bold" FontSize="11" Foreground="Gray" Grid.Column="5" Margin="45,0,0,0"/>
                                <TextBlock Text="EMERGENCY" FontWeight="Bold" FontSize="11" Foreground="Gray" Grid.Column="6" Margin="30,0,0,0"/>
                            </Grid>
                        </ListView.Header>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="entity:Patient">
                                <Grid Padding="12,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding FirstName}" Grid.Column="0" Foreground="{Binding IsDeceased, Converter={StaticResource DeceasedToColor}}" Margin="10,0,0,0"/>
                                    <TextBlock Text="{Binding LastName}" Grid.Column="1" Foreground="{Binding IsDeceased, Converter={StaticResource DeceasedToColor}}" Margin="10,0,0,0"/>
                                    <TextBlock Text="{Binding Sex}" Grid.Column="2" Foreground="Black" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Dob, Converter={StaticResource DateToStringConverter}}" Foreground="Black" Grid.Column="3" Margin="10,0,0,0" />
                                    <TextBlock Text="{Binding Cnp}" Grid.Column="4" Foreground="Black" FontSize="12" Margin="10,0,0,0"/>
                                    <TextBlock Text="{Binding PhoneNo}" Grid.Column="5" Foreground="Black" Margin="10,0,0,0"/>
                                    <TextBlock Text="{Binding EmergencyContact}" Grid.Column="6" Foreground="Black" FontStyle="Italic" Margin="10,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </StackPanel>
        </Grid>

        <Border Grid.Column="2" Background="#1F2A37" Padding="20" Visibility="{Binding SelectedPatient, Converter={StaticResource NullToVisibilityConverter}}">
            <Grid>
                <StackPanel Spacing="10" Visibility="{Binding IsActiveMode, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Patient Details" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
                    <TextBlock Text="Phone Number" Foreground="White"/>
                    <TextBox Text="{Binding EditingPatient.PhoneNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Emergency Contact" Foreground="White"/>
                    <TextBox Text="{Binding EditingPatient.EmergencyContact, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Update Patient" Command="{Binding UpdatePatientCommand}" HorizontalAlignment="Stretch" Margin="0,15,0,0" CornerRadius="6"/>
                    <Button Content="Archive Patient" Command="{Binding ArchivePatientCommand}" HorizontalAlignment="Stretch" Foreground="Red" CornerRadius="6"/>
                    <Button Content="Mark as Deceased" Command="{Binding MarkAsDeceasedCommand}" HorizontalAlignment="Stretch" IsEnabled="{Binding IsNotDeceased}" CornerRadius="6"/>
                </StackPanel>

                <StackPanel Spacing="10" Visibility="{Binding IsArchivedMode, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Archive Actions" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
                    <Button Content="Restore to Active" Command="{Binding DearchivePatientCommand}" IsEnabled="{Binding IsNotDeceased}" HorizontalAlignment="Stretch" CornerRadius="6"/>
                    <Button Content="Mark as Deceased" Command="{Binding MarkAsDeceasedCommand}" IsEnabled="{Binding IsNotDeceased}" Background="#442222" HorizontalAlignment="Stretch" CornerRadius="6"/>
                    <Button Content="Register Organ Donor" Command="{Binding MarkAsOrganDonorCommand}" Visibility="{Binding SelectedPatient.IsDeceased, Converter={StaticResource BoolToVis}}" Background="#224422" HorizontalAlignment="Stretch" CornerRadius="6"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.ColumnSpan="3" Background="#F0000000" IsHitTestVisible="True" Visibility="{Binding IsExorcismAlertVisible, Converter={StaticResource BoolToVis}}">
            <Border MaxWidth="600" CornerRadius="16" Background="#1A0000" BorderBrush="#CC0000" BorderThickness="3" Padding="48,40" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Spacing="20" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE7BA;" FontSize="72" Foreground="#CC0000" HorizontalAlignment="Center"/>
                    <TextBlock Text="CRITICAL PARANORMAL ACTIVITY DETECTED" Foreground="#FF3333" FontSize="20" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock Text="Multiple sightings confirmed. Please CALL THE PRIEST immediately." Foreground="White" FontSize="16" TextAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>