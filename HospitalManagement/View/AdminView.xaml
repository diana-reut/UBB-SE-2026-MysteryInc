<Window
    x:Class="HospitalManagement.View.AdminView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:entity="using:HospitalManagement.Entity"
    xmlns:converters="using:HospitalManagement.Converters"
    Title="Admin Dashboard - Hospital Management">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>

        <Grid.Resources>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <converters:DateToStringConverter x:Key="DateToStringConverter"/>
        </Grid.Resources>

        <!-- 3 COLUMN LAYOUT -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- ================================= -->
        <!-- LEFT SIDEBAR -->
        <!-- ================================= -->

        <Border Grid.Column="0"
            Background="#1F2A37"
            Padding="20">

            <StackPanel Spacing="15">

                <TextBlock Text="HOSPITAL"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,20"/>

                <Button Content="Home"
                    Command="{Binding NavigateToHomeCommand}"
                    Height="40"
                    CornerRadius="8"/>

                <Button Click="OpenPage_Click"
                    Height="40"
                    CornerRadius="8">

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="FourBars"/>
                        <TextBlock Text="Statistics"/>
                    </StackPanel>

                </Button>

                <Border Height="1"
        Background="#3A4758"
        Margin="0,20,0,20"/>

                <TextBlock Text="Quick Info"
                       FontSize="16"
                       Foreground="LightGray"
                       Margin="0,10,0,0"/>

                <Border Background="#2C3A4A"
                    CornerRadius="8"
                    Padding="10">

                    <StackPanel>
                        <TextBlock Text="Patients"
                               FontWeight="Bold"/>
                        <TextBlock Text="{Binding Patients.Count}"/>
                    </StackPanel>

                </Border>

            </StackPanel>

        </Border>


        <!-- ================================= -->
        <!-- MAIN SECTION -->
        <!-- ================================= -->

        <Grid Grid.Column="1"
          Padding="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <!-- SEARCH BAR -->
            <Border Background="#2C3A4A"
                Padding="15"
                CornerRadius="10"
                Margin="0,0,0,15">

                <StackPanel Orientation="Horizontal"
                        Spacing="15">

                    <TextBox PlaceholderText="Search by Name or CNP..."
                         Width="250"
                         Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <Button Content="Add New Patient"
                        Click="OpenAddPatientDialog"
                        CornerRadius="6"/>

                </StackPanel>

            </Border>


            <!-- PATIENT TABLE -->

            <Border Grid.Row="1"
                Background="#F8FAFC"
                CornerRadius="10"
                Padding="10">

                <ListView
                ItemsSource="{Binding Patients}"
                SelectedItem="{Binding SelectedPatient, Mode=TwoWay}"
                SelectionMode="Single">

                    <ListView.Header>

                        <Grid Padding="10"
                          Background="#E5E7EB">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="FIRST NAME" FontWeight="Bold" Grid.Column="0" Foreground="Black"/>
                            <TextBlock Text="LAST NAME" FontWeight="Bold" Grid.Column="1" Foreground="Black"/>
                            <TextBlock Text="SEX" FontWeight="Bold" Grid.Column="2" Foreground="Black"/>
                            <TextBlock Text="DOB" FontWeight="Bold" Grid.Column="3" Foreground="Black"/>
                            <TextBlock Text="CNP" FontWeight="Bold" Grid.Column="4" Foreground="Black"/>
                            <TextBlock Text="PHONE" FontWeight="Bold" Grid.Column="5" Foreground="Black"/>
                            <TextBlock Text="EMERGENCY" FontWeight="Bold" Grid.Column="6" Foreground="Black"/>

                        </Grid>

                    </ListView.Header>


                    <ListView.ItemTemplate>

                        <DataTemplate x:DataType="entity:Patient">

                            <Grid Padding="10">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding FirstName}" Grid.Column="0" Foreground="Black"/>
                                <TextBlock Text="{Binding LastName}" Grid.Column="1" Foreground="Black"/>
                                <TextBlock Text="{Binding Sex}" Grid.Column="2" Foreground="Black"/>
                                <TextBlock Text="{Binding Dob, Converter={StaticResource DateToStringConverter}}" Grid.Column="3" Foreground="Black"/>
                                <TextBlock Text="{Binding Cnp}" Grid.Column="4" Foreground="Black"/>
                                <TextBlock Text="{Binding PhoneNo}" Grid.Column="5" Foreground="Black"/>
                                <TextBlock Text="{Binding EmergencyContact}" Grid.Column="6" Foreground="Black"/>

                            </Grid>

                        </DataTemplate>

                    </ListView.ItemTemplate>

                </ListView>

            </Border>

        </Grid>



        <!-- ================================= -->
        <!-- RIGHT EDIT PANEL -->
        <!-- ================================= -->

        <Border Grid.Column="2"
           Background="#1F2A37"
            Padding="20"
            Visibility="{Binding SelectedPatient, Converter={StaticResource NullToVisibilityConverter}}">

            <StackPanel Spacing="10">

                <TextBlock Text="Patient Details"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>

                <TextBlock Text="Phone Number"/>
                <TextBox Text="{Binding EditingPatient.PhoneNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Emergency Contact"/>
                <TextBox Text="{Binding EditingPatient.EmergencyContact, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="Update Patient"
                    Command="{Binding UpdatePatientCommand}"
                    Margin="0,15,0,0"
                    CornerRadius="6"/>

                <Button Content="Archive Patient"
                    Command="{Binding ArchivePatientCommand}"
                    Foreground="Red"
                    CornerRadius="6"/>

                <Button Content="Mark as Deceased"
                    Command="{Binding MarkAsDeceasedCommand}"
                    IsEnabled="{Binding IsNotDeceased}"
                    CornerRadius="6"/>

            </StackPanel>

        </Border>

    </Grid>
</Window>