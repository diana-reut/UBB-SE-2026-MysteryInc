<Page
    x:Class="HospitalManagement.View.BloodDonorsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:HospitalManagement.ViewModel"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Top 20 Compatible Blood Donors" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,20"/>

        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Donors, Mode=OneWay}" SelectionMode="None">
            <ListView.Header>
                <Grid Padding="12,8" Background="{ThemeResource LayerFillColorAltBrush}" CornerRadius="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="First Name" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="Last Name" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="2" Text="CNP" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="3" Text="Blood Type" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="4" Text="Rh Factor" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="5" Text="Score" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Grid>
            </ListView.Header>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:DonorMatchModel">
                    <Grid Padding="12,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{x:Bind FirstName}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind LastName}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{x:Bind Cnp}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="{x:Bind BloodType}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="4" Text="{x:Bind RhFactor}" VerticalAlignment="Center" FontWeight="SemiBold"/>

                        <TextBlock Grid.Column="5" Text="{x:Bind Score}" VerticalAlignment="Center" FontWeight="Bold" Foreground="#4CAF50"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>