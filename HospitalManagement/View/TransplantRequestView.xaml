<Page
    x:Class="HospitalManagement.View.TransplantRequestView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="30">
        <StackPanel Spacing="20" Width="400" HorizontalAlignment="Left">
            <TextBlock Text="Waitlist Entry Form" FontSize="22" FontWeight="SemiBold"/>
            <TextBlock Text="{x:Bind ViewModel.PatientName}" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <Border Background="#22FF0000" BorderBrush="Red" BorderThickness="1" CornerRadius="4" Padding="12" 
                    Visibility="{x:Bind ViewModel.UrgentVisibility, Mode=OneWay}">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="!" FontSize="20" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="URGENT PRIORITY" Foreground="Red" FontWeight="Bold"/>
                        <TextBlock Text="(10+ ER Visits in last 3 months)" Foreground="Red" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="#22FFA500" BorderBrush="Orange" BorderThickness="1" CornerRadius="4" Padding="12" 
                    Visibility="{x:Bind ViewModel.WarningVisibility, Mode=OneWay}">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="F" FontSize="20" VerticalAlignment="Center"/>
                    <TextBlock Text="{x:Bind ViewModel.WarningMessage, Mode=OneWay}" Foreground="Orange" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" Width="300"/>
                </StackPanel>
            </Border>

            <ComboBox Header="Select Required Organ" 
                      SelectedItem="{x:Bind ViewModel.SelectedOrgan, Mode=TwoWay}"
                      HorizontalAlignment="Stretch"
                      PlaceholderText="Choose Organ...">
                <x:String>Kidney</x:String>
                <x:String>Heart</x:String>
                <x:String>Liver</x:String>
                <x:String>Lungs</x:String>
                <x:String>Pancreas</x:String>
            </ComboBox>
            <TextBlock
                Foreground="#D13438"
                Visibility="{x:Bind ViewModel.HasError, Mode=OneWay}"
                Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,20,0,0">

                <Button Content="Submit Request"
                        Command="{x:Bind ViewModel.SubmitRequestCommand}"
                        Style="{StaticResource AccentButtonStyle}"/>

                <Button Content="Cancel"
                        Command="{x:Bind ViewModel.CancelCommand}"/>

            </StackPanel>
        </StackPanel>
    </Grid>
</Page>