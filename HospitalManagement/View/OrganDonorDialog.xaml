<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="HospitalManagement.View.OrganDonorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:HospitalManagement.Utils"
    xmlns:local="using:HospitalManagement.ViewModel"
    Title="Organ Donor Assignment"
    PrimaryButtonText="Confirm Assignment"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <ContentDialog.Resources>
        <helpers:StringVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </ContentDialog.Resources>

    <Grid RowSpacing="15" Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Info -->
        <StackPanel Grid.Row="0" Spacing="5">
            <TextBlock Text="Select Organ &amp; Best Recipient Match" FontSize="16" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding DeceasedPatient.FirstName}" FontSize="12" Foreground="Gray"/>
            <TextBlock Text="{Binding DeceasedPatient.LastName}" FontSize="12" Foreground="Gray"/>
        </StackPanel>

        <!-- Organ Selection -->
        <StackPanel Grid.Row="1" Spacing="8">
            <TextBlock Text="Select Organ" FontWeight="SemiBold"/>
            <ComboBox 
                ItemsSource="{Binding Organs}" 
                SelectedItem="{Binding SelectedOrgan, Mode=TwoWay}"
                PlaceholderText="Choose an organ..."/>
        </StackPanel>

        <!-- Error Message Display -->
        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="Red" 
                   TextWrapping="Wrap" FontSize="12"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

        <!-- Loading State -->
        <StackPanel Grid.Row="3" Visibility="{Binding IsLoading}" Spacing="8" HorizontalAlignment="Center">
            <ProgressRing IsActive="{Binding IsLoading}"/>
            <TextBlock Text="{Binding LoadingMessage}" Foreground="Gray" TextAlignment="Center"/>
        </StackPanel>

        <!-- Top 5 Matches Grid -->
        <StackPanel Grid.Row="4" Spacing="10">
            <TextBlock Text="Top 5 Compatible Recipients" FontWeight="SemiBold"/>
            
            <ListView
                ItemsSource="{Binding TopMatches}"
                SelectedItem="{Binding SelectedMatch, Mode=TwoWay}"
                SelectionMode="Single"
                Height="300"
                Padding="10"
                BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}" 
                BorderThickness="1"
                CornerRadius="8">
                <ListView.Header>
                    <Grid Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" 
                          Padding="12,8" CornerRadius="4" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="RECIPIENT" FontWeight="Bold" FontSize="12" Foreground="Gray" Grid.Column="0" Margin="10,0,0,0"/>
                        <TextBlock Text="BLOOD" FontWeight="Bold" FontSize="12" Foreground="Gray" Grid.Column="1" Margin="10,0,0,0"/>
                        <TextBlock Text="SCORE %" FontWeight="Bold" FontSize="12" Foreground="Gray" Grid.Column="2" Margin="10,0,0,0"/>
                        <TextBlock Text="WAITING" FontWeight="Bold" FontSize="12" Foreground="Gray" Grid.Column="3" Margin="10,0,0,0"/>
                    </Grid>
                </ListView.Header>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:TransplantMatch">
                        <Grid Padding="12,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding ReceiverName}" VerticalAlignment="Center" Grid.Column="0" Margin="10,0,0,0"/>
                            <TextBlock Text="{Binding BloodType}" VerticalAlignment="Center" Grid.Column="1" Margin="10,0,0,0"/>
                            <TextBlock Text="{Binding CompatibilityScore}" VerticalAlignment="Center" Grid.Column="2" FontWeight="SemiBold" Margin="10,0,0,0"/>
                            <TextBlock Text="{Binding WaitingDays}" VerticalAlignment="Center" Grid.Column="3" Margin="10,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Margin" Value="0,2"/>
                        <Setter Property="BorderBrush" Value="{ThemeResource SystemControlBackgroundBaseLowBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

            <TextBlock 
                Text="{Binding LoadingMessage}" 
                Foreground="OrangeRed" 
                TextAlignment="Center"
                Visibility="{Binding LoadingMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
        </StackPanel>
    </Grid>
</ContentDialog>

