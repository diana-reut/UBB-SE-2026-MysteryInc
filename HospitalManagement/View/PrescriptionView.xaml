<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="HospitalManagement.View.PrescriptionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HospitalManagement.View"
    xmlns:entity="using:HospitalManagement.Entity"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BrandDark" Color="#1E2A38"/>
        <SolidColorBrush x:Key="BrandPrimary" Color="#2A6478"/>
        <SolidColorBrush x:Key="BrandSecondary" Color="#4A90A4"/>
        <SolidColorBrush x:Key="BrandAccent" Color="#5EC499"/>
        <SolidColorBrush x:Key="GhostAccent" Color="#FFE779"/>

        <Style x:Key="AccentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BrandAccent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <Grid Padding="20" Background="#F4F6F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="*"/>    
            <RowDefinition Height="Auto"/> 
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="PRESCRIPTIONS FEED" FontSize="14" FontWeight="Bold" Foreground="{StaticResource BrandSecondary}" CharacterSpacing="50"/>
            <TextBlock Text="Chronological Overview" FontSize="26" Foreground="{StaticResource BrandDark}" FontWeight="Bold" Margin="0,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="{StaticResource BrandDark}" 
                CornerRadius="8" Padding="20,10,20,10" Margin="0,0,0,10"
                HorizontalAlignment="Left">
            <StackPanel>
                <TextBlock Text="Filter Options" FontWeight="SemiBold" FontSize="14" Foreground="White" Margin="0,0,0,6"/>

                <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <TextBox x:Name="SearchIdBox" PlaceholderText="ID..." Width="60" Height="36" CornerRadius="6" VerticalContentAlignment="Center"/>
                    <TextBox x:Name="SearchNameBox" PlaceholderText="Patient Name" Width="160" Height="36" CornerRadius="6" VerticalContentAlignment="Center"/>
                    <TextBox x:Name="SearchMedBox" PlaceholderText="Medication Name" Width="150" Height="36" CornerRadius="6" VerticalContentAlignment="Center"/>

                    <CalendarDatePicker x:Name="DateFromPicker" PlaceholderText="Date From" Width="140" Height="36" CornerRadius="6" VerticalAlignment="Center"/>
                    <TextBlock Text="-" VerticalAlignment="Center" Foreground="#A1A1AA" FontWeight="Bold"/>
                    <CalendarDatePicker x:Name="DateToPicker" PlaceholderText="Date To" Width="140" Height="36" CornerRadius="6" VerticalAlignment="Center"/>

                    <Button Content="Search" Style="{StaticResource AccentButtonStyle}" 
                            Click="OnApplyFilterClicked" Width="90" Height="36" Margin="10,0,0,0"/>
                
                <TextBlock Text="{x:Bind ViewModel.InfoMessage, Mode=OneWay}" 
                           Foreground="{StaticResource GhostAccent}" FontWeight="SemiBold" 
                           VerticalAlignment="Center" Margin="15,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
             <GridView ItemsSource="{x:Bind ViewModel.Prescriptions, Mode=OneWay}"
                       SelectionMode="None"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch">

                 <GridView.ItemsPanel>
                     <ItemsPanelTemplate>
                         <ItemsWrapGrid MaximumRowsOrColumns="3" Orientation="Horizontal" HorizontalAlignment="Center"/>
                     </ItemsPanelTemplate>
                 </GridView.ItemsPanel>

                 <GridView.ItemTemplate>
                    <DataTemplate x:DataType="entity:Prescription">
                       
                        <Border Background="White"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1" CornerRadius="10"
                            Width="280" Height="135" Margin="6" Padding="5">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Button Grid.Row="0" HorizontalAlignment="Center" Background="#F0F9F6" BorderBrush="{ThemeResource BrandAccent}" BorderThickness="1" CornerRadius="20" Padding="10,2">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE814;" Foreground="{ThemeResource BrandPrimary}" FontSize="12"/>
                                        <TextBlock Text="{x:Bind Id}" FontSize="14" FontWeight="Bold" Foreground="{ThemeResource BrandPrimary}" />
                                    </StackPanel>

                                    <Button.Flyout>
                                        <Flyout>
                                            <Flyout.FlyoutPresenterStyle>
                                                <Style TargetType="FlyoutPresenter">
                                                    <Setter Property="Background" Value="White"/>
                                                    <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Setter Property="CornerRadius" Value="10"/>
                                                    <Setter Property="Padding" Value="0"/>
                                                </Style>
                                            </Flyout.FlyoutPresenterStyle>
                                            <StackPanel Width="230" Padding="15">
                                                <TextBlock Text="Medication Details" FontWeight="Bold" FontSize="15" Foreground="#1E2A38" Margin="0,0,0,15"/>
                                                <ListView ItemsSource="{x:Bind MedicationList}" SelectionMode="None">
                                                    <ListView.ItemTemplate>
                                                        <DataTemplate x:DataType="entity:PrescriptionItem">
                                                            <Grid Margin="0,4">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <FontIcon Glyph="&#xE1D0;" Foreground="#6B7280" FontSize="11" VerticalAlignment="Center"/>
                                                                    <TextBlock Grid.Column="0" Text="{x:Bind MedName}" FontSize="12" FontWeight="SemiBold" Foreground="#1E2A38" TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                                <Border Grid.Column="1" Background="#F4F6F8" CornerRadius="4" Padding="6,2" BorderBrush="#E5E7EB" BorderThickness="1" VerticalAlignment="Center" Margin="5,0,0,0">
                                                                    <TextBlock Text="{x:Bind Quantity}" FontSize="10" FontWeight="SemiBold" Foreground="#4B5563"/>
                                                                </Border>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ListView.ItemTemplate>
                                                </ListView>
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>

                                <StackPanel Grid.Row="1" Margin="0,5,0,0" Spacing="1">
                                    <TextBlock FontSize="11" TextTrimming="CharacterEllipsis">
                                        <Run Text="Patient: " FontWeight="SemiBold" Foreground="#1E2A38"/>
                                        <Run Text="{x:Bind PatientName}" Foreground="#4B5563"/>
                                    </TextBlock>
                                    <TextBlock FontSize="11" TextTrimming="CharacterEllipsis">
                                        <Run Text="Doctor: " FontWeight="SemiBold" Foreground="#1E2A38"/>
                                        <Run Text="{x:Bind DoctorName}" Foreground="#4B5563"/>
                                    </TextBlock>
                                    <TextBlock Margin="0,2,0,0">
                                        <Run Text="Instructions:" FontWeight="SemiBold" FontSize="10" Foreground="#1E2A38"/>
                                    </TextBlock>
                                    <TextBlock Text="{x:Bind DoctorNotes}" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" Foreground="#4B5563" FontSize="10"/>
                                </StackPanel>

                                <Border Grid.Row="2" Background="#F4F6F8" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon Glyph="&#xE787;" FontSize="10" Foreground="#6B7280" VerticalAlignment="Center"/>
                                        <TextBlock Foreground="#6B7280" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center">
                                            <Run Text="{x:Bind Date.ToString()}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                 </GridView.ItemTemplate>

             </GridView>
        </ScrollViewer>


        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="30" Margin="0,20,0,0">

            <Button Click="OnPrevClicked" Width="110" Height="40" CornerRadius="20" Background="#00a896" BorderThickness="0" Foreground="White">

                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackground" Color="#00a896"/>
                    <SolidColorBrush x:Key="ButtonForeground" Color="White"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#028090"/>
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#005C66"/>
                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                </Button.Resources>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72B;" FontSize="12"/>
                    <TextBlock Text="Previous" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>
            
            <Border Background="{StaticResource BrandDark}" CornerRadius="20" Padding="20,0" Height="40">
                <TextBlock FontSize="14" VerticalAlignment="Center" Foreground="White" FontWeight="Bold">
                    <Run Text="PAGE "/>
                    <Run Text="{x:Bind ViewModel.CurrentPage, Mode=OneWay}"/>
                </TextBlock>
            </Border>

                <Button Click="OnNextClicked" Width="110" Height="40" CornerRadius="20" Background="#00a896" BorderThickness="0" Foreground="White">

                    <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackground" Color="#00a896"/>
                    <SolidColorBrush x:Key="ButtonForeground" Color="White"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#028090"/>
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#005C66"/>
                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                </Button.Resources>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Next" FontWeight="SemiBold"/>
                    <FontIcon Glyph="&#xE72A;" FontSize="12"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
