<ContentDialog
    x:Class="HospitalManagement.View.MedicalHistoryDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Add Medical History"
    PrimaryButtonText="Save"
    CloseButtonText="Skip"
    DefaultButton="Primary"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick">

    <StackPanel Spacing="12" Width="400" Margin="0,10,0,0">
        <!-- Blood Type -->
        <StackPanel Spacing="5">
            <TextBlock Text="Blood Type" Foreground="Gray" FontSize="12" FontWeight="SemiBold"/>
            <ComboBox x:Name="BloodTypeEntry" HorizontalAlignment="Stretch" SelectedIndex="0">
                <ComboBoxItem Content="A"/>
                <ComboBoxItem Content="B"/>
                <ComboBoxItem Content="AB"/>
                <ComboBoxItem Content="O"/>
            </ComboBox>
        </StackPanel>

        <!-- RH Factor -->
        <StackPanel Spacing="5">
            <TextBlock Text="RH Factor" Foreground="Gray" FontSize="12" FontWeight="SemiBold"/>
            <ComboBox x:Name="RhFactorEntry" HorizontalAlignment="Stretch" SelectedIndex="0">
                <ComboBoxItem Content="Positive"/>
                <ComboBoxItem Content="Negative"/>
            </ComboBox>
        </StackPanel>

        <!-- Chronic Conditions -->
        <StackPanel Spacing="5">
            <TextBlock Text="Chronic Conditions (comma-separated)" Foreground="Gray" FontSize="12" FontWeight="SemiBold"/>
            <TextBox x:Name="ChronicConditionsEntry" 
                     PlaceholderText="e.g. diabetes, hypertension, asthma"
                     TextWrapping="Wrap"
                     Height="80"
                     AcceptsReturn="True"/>
        </StackPanel>

        <!-- Allergies Section -->
        <StackPanel Spacing="5">
            <TextBlock Text="Allergies" Foreground="Gray" FontSize="12" FontWeight="SemiBold"/>
            
            <!-- Allergy Input Row -->
            <StackPanel Spacing="5" Orientation="Horizontal">
                <ComboBox x:Name="AllergyNameEntry" 
                         Width="150"/>
                <ComboBox x:Name="AllergySeverityEntry" Width="100" SelectedIndex="0">
                    <ComboBoxItem Content="Mild"/>
                    <ComboBoxItem Content="Moderate"/>
                    <ComboBoxItem Content="Severe"/>
                    <ComboBoxItem Content="Anaphylactic"/>
                </ComboBox>
                <Button x:Name="AddAllergyButton" 
                        Content="Add"
                        Width="60"
                        Click="AddAllergyButton_Click"/>
            </StackPanel>

            <!-- Allergies List -->
            <ListBox x:Name="AllergiesList" 
                     Height="120"
                     Background="LightGray"
                     Foreground="Black"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*,Auto,Auto" Padding="10,6" Background="White">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Allergy.AllergyName}" 
                                       VerticalAlignment="Center"
                                       Foreground="Black"
                                       FontSize="14"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Severity}" 
                                       VerticalAlignment="Center"
                                       Foreground="Black"
                                       FontSize="14"
                                       Margin="16,0"/>
                            <Button Grid.Column="2"
                                    Content="Remove" 
                                     Background="#333333"
                                    Foreground="White"
                                    Tag="{Binding}" 
                                    Click="RemoveAllergyButton_Click"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </StackPanel>
</ContentDialog>
