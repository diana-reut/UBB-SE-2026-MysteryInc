<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="HospitalManagement.View.DiscountRouletteDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Discount Roulette"
    DefaultButton="None"
    IsSecondaryButtonEnabled="False">

    <Grid Padding="20" RowSpacing="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="300"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="5">
            <TextBlock Text="Try Your Luck - Spin the Wheel!" FontSize="16" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Base Price:" FontSize="12" Foreground="Gray"/>
            <TextBlock Text="{Binding BasePrice}" FontSize="18" FontWeight="SemiBold" Foreground="#00FF00"/>
        </StackPanel>

        <!-- Roulette Wheel (Circle with segments) -->
        <Border Grid.Row="1" Background="#1F2A37" CornerRadius="10" HorizontalAlignment="Center" 
                Width="300" Height="300" Padding="20">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Wheel background circle -->
                <Ellipse Width="250" Height="250" Fill="#2A3F54" Stroke="#FFD700" StrokeThickness="3"/>
                
                <!-- Wheel segments (simple colored sections) -->
                <Canvas Width="250" Height="250" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- 0% - Red -->
                    <Ellipse Canvas.Left="-125" Canvas.Top="-125" Width="250" Height="250" Fill="#FF4444" Opacity="0.3"/>
                    <!-- 10% - Orange -->
                    <Ellipse Canvas.Left="-125" Canvas.Top="-125" Width="250" Height="250" Fill="#FF8844" Opacity="0.3"/>
                    <!-- 25% - Yellow -->
                    <Ellipse Canvas.Left="-125" Canvas.Top="-125" Width="250" Height="250" Fill="#FFCC44" Opacity="0.3"/>
                    <!-- 50% - Green -->
                    <Ellipse Canvas.Left="-125" Canvas.Top="-125" Width="250" Height="250" Fill="#44CC44" Opacity="0.3"/>
                    <!-- 100% - Blue -->
                    <Ellipse Canvas.Left="-125" Canvas.Top="-125" Width="250" Height="250" Fill="#4444FF" Opacity="0.3"/>
                </Canvas>
                
                <!-- Center circle overlay -->
                <Ellipse Width="80" Height="80" Fill="#1F2A37" Stroke="#FFD700" StrokeThickness="2"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                
                <!-- Center button - SPIN (ONLY BUTTON) -->
                <Button x:Name="SpinButton" Width="70" Height="70" CornerRadius="35" 
                        Background="#FFD700" Foreground="Black" 
                        Content="SPIN" FontWeight="Bold" FontSize="16"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Click="SpinButton_Click"
                        IsEnabled="{Binding IsPrimaryButtonEnabled}"/>
            </Grid>
        </Border>

        <!-- Discount Options Display -->
        <StackPanel Grid.Row="2" Spacing="8">
            <TextBlock Text="Possible Discounts:" FontSize="12" FontWeight="SemiBold" Foreground="Gray"/>
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Background="#FF4444" Padding="10" CornerRadius="6" Grid.Column="0">
                    <TextBlock Text="0%" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Border>
                <Border Background="#FF8844" Padding="10" CornerRadius="6" Grid.Column="1">
                    <TextBlock Text="10%" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Border>
                <Border Background="#FFCC44" Padding="10" CornerRadius="6" Grid.Column="2">
                    <TextBlock Text="25%" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Border>
                <Border Background="#44CC44" Padding="10" CornerRadius="6" Grid.Column="3">
                    <TextBlock Text="50%" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Border>
                <Border Background="#4444FF" Padding="10" CornerRadius="6" Grid.Column="4">
                    <TextBlock Text="100%" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </StackPanel>

        <!-- Result Display -->
        <StackPanel Grid.Row="3" Spacing="8" Visibility="{Binding ShowResult}">
            <TextBlock Text="{Binding DiscountPercentage}" 
                       FontSize="18" FontWeight="Bold" Foreground="#FFD700"/>
            <TextBlock Text="{Binding FinalPrice}" 
                       FontSize="16" FontWeight="Bold" Foreground="#00FF00"/>
        </StackPanel>
    </Grid>
</ContentDialog>
