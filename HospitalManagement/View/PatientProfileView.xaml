<Page
    x:Class="HospitalManagement.View.PatientProfileView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:entity="using:HospitalManagement.Entity"
    xmlns:converters="using:HospitalManagement.Converters">

    <Page.Resources>
        <converters:DateToStringConverter x:Key="DateConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVis" />
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,20">
            <TextBlock Text="Patient Medical Profile" FontSize="26" FontWeight="Bold" Foreground="#ffffff" VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="10">
                <Button Content="Import from ER" Click="ImportER_ClickAsync" Style="{ThemeResource AccentButtonStyle}"/>
                <Button Content="Import from Staff" Click="ImportStaff_ClickAsync" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Margin="0,0,10,0" Padding="20" CornerRadius="8">
            <ScrollViewer>
                <StackPanel Spacing="8">

                    <TextBlock Text="General Information" FontSize="20" FontWeight="Bold" Foreground="#ffffff" Margin="0,0,0,10"/>

                    <TextBlock Text="{x:Bind ViewModel.CurrentPatient.FirstName, Mode=OneWay, FallbackValue='Loading...'}" FontSize="18"/>
                    <TextBlock Text="{x:Bind ViewModel.CurrentPatient.LastName, Mode=OneWay, FallbackValue=''}" FontSize="18"/>
                    <TextBlock Text="{x:Bind ViewModel.CurrentPatient.Cnp, Mode=OneWay, FallbackValue=''}" Foreground="Gray" Margin="0,0,0,10"/>

                    <MenuFlyoutSeparator Margin="0,10"/>

                    <TextBlock Text="Medical History" FontWeight="SemiBold" FontSize="16"/>

                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="Blood Type: " Foreground="Gray"/>
                        <TextBlock Text="{x:Bind ViewModel.CurrentPatient.MedicalHistory.BloodType, Mode=OneWay, TargetNullValue='N/A', FallbackValue='N/A'}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="RH Factor: " Foreground="Gray"/>
                        <TextBlock Text="{x:Bind ViewModel.CurrentPatient.MedicalHistory.Rh, Mode=OneWay, TargetNullValue='N/A', FallbackValue='N/A'}"/>
                    </StackPanel>

                    <StackPanel Spacing="2">
                        <TextBlock Text="Allergies: " Foreground="Gray"/>
                        <TextBlock Text="{x:Bind ViewModel.FormattedAllergies, Mode=OneWay}" TextWrapping="Wrap" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel Spacing="2">
                        <TextBlock Text="Chronic Conditions: " Foreground="Gray"/>
                        <TextBlock Text="{x:Bind ViewModel.FormattedChronicConditions, Mode=OneWay}" TextWrapping="Wrap" Margin="10,0,0,0"/>
                    </StackPanel>

                    <MenuFlyoutSeparator Margin="0,10"/>

                    <Expander Header="File Records" HorizontalAlignment="Stretch">
                        <ListView ItemsSource="{x:Bind ViewModel.CurrentPatient.MedicalHistory.MedicalRecords, Mode=OneWay}"
                                  DoubleTapped="RecordList_DoubleTapped"
                                  SelectionMode="Single">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="entity:MedicalRecord">
                                    <TextBlock Text="{x:Bind ConsultationDate, Converter={StaticResource DateConverter}}" Padding="0,5" FontWeight="SemiBold"/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Margin="10,0,0,0" Padding="20" CornerRadius="8">
            <StackPanel Visibility="{x:Bind ViewModel.SelectedRecord, Mode=OneWay, Converter={StaticResource NullToVis}, FallbackValue=Collapsed}" Spacing="15">
                <TextBlock Text="Consultation Details" FontSize="20" FontWeight="Bold" Foreground="#ffffff" Margin="0,0,0,10"/>

                <Grid ColumnSpacing="15" RowSpacing="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Patient Name:" Foreground="Gray"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.CurrentPatient.FullName, Mode=OneWay}" FontWeight="SemiBold"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Date:" Foreground="Gray"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.SelectedRecord.ConsultationDate, Mode=OneWay, Converter={StaticResource DateConverter}}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Source:" Foreground="Gray"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.SelectedRecord.SourceType, Mode=OneWay}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Staff ID:" Foreground="Gray"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.SelectedRecord.StaffId, Mode=OneWay}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Reported Symptoms:" Foreground="Gray"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{x:Bind ViewModel.SelectedRecord.Symptoms, Mode=OneWay}" TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Diagnosis:" Foreground="Gray"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{x:Bind ViewModel.SelectedRecord.Diagnosis, Mode=OneWay}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                    <Button Content="View Associated Prescription"
                            Click="ViewPrescription_ClickAsync"
                            Style="{ThemeResource AccentButtonStyle}"
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0"/>

                    <Button Content="Export to PDF"
                            Style="{ThemeResource AccentButtonStyle}"
                            Click="ExportPDF_ClickAsync"
                            Margin="0,10,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>