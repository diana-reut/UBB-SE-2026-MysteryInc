<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="HospitalManagement.View.PharmacistView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HospitalManagement.View"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Pharmacist Dashboard">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="#F4F6F8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/> 
            <ColumnDefinition Width="*"/>   
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#1E2A38" Padding="15">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/> 
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- MENIUL DE SUS -->
            <StackPanel Grid.Row="0" Spacing="10" Margin="0,20,0,0">
                <TextBlock Text="PHARMACY" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                
                <Button Content="Prescriptions" 
                        Command="{Binding ShowPrescriptionsCommand}"
                        Background="Transparent" 
                        Foreground="White" 
                        HorizontalAlignment="Stretch" 
                        BorderBrush="#2A6478" 
                        BorderThickness="1"
                        Padding="10"/>

                <Button Content="See All Addicts" 
                        Command="{Binding ShowAddictsCommand}"
                        Background="Transparent" 
                        Foreground="White" 
                        HorizontalAlignment="Stretch" 
                        BorderBrush="#2A6478" 
                        BorderThickness="1"
                        Padding="10"/>
            </StackPanel>

            <!-- PARTEA DE JOS: GHOST SIGHTING & BACK TO HOME -->
            <StackPanel Grid.Row="1" Spacing="10" Margin="0,0,0,10">
                
                <!-- Butonul nou: I saw a ghost! -->
                <Button Command="{Binding ReportGhostCommand}"
                        HorizontalAlignment="Stretch" 
                        Background="#FFE779" 
                        BorderBrush="Transparent"
                        Padding="10" 
                        CornerRadius="4"
                        ToolTipService.ToolTip="Report Paranormal Activity">
                    
                    <!-- Adăugăm Resurse Speciale pentru a suprascrie Hover-ul -->
                    <Button.Resources>
                        <!-- Culoarea când dai hover (o nuanță mai intensă de galben/portocaliu) -->
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFD54F"/>
                        <!-- Păstrăm culoarea textului închisă și la hover -->
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#1E2A38"/>
                        
                        <!-- Culoarea când dai click efectiv pe buton (Pressed) -->
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#FFC107"/>
                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#1E2A38"/>
                    </Button.Resources>

                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE7BA;" Margin="0,0,8,0" FontSize="14" Foreground="#1E2A38"/>
                                <TextBlock Text="I saw a ghost!" Foreground="#1E2A38" FontWeight="Bold"/>
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>

                <!-- Butonul existent: Back to Home -->
                <Button Content="Back to Home" 
                        Click="BackToHomeButton_Click"
                        HorizontalAlignment="Stretch"
                        Background="#2A6478"
                        Foreground="White"
                        CornerRadius="4"
                        Padding="10,8">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE72B;" Margin="0,0,8,0" FontSize="14"/>
                                <TextBlock Text="{Binding}" FontWeight="SemiBold"/>
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>

            </StackPanel>
        </Grid>

        <ContentControl x:Name="MainContentArea" Grid.Column="1" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"/>
    </Grid>
</Window>
