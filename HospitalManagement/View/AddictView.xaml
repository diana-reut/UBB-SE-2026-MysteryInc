<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Name="Root"
    x:Class="HospitalManagement.View.AddictView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HospitalManagement.View"
    xmlns:entity="using:HospitalManagement.Entity"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BrandDark" Color="#1E2A38"/>
        <SolidColorBrush x:Key="DangerRed" Color="#E53E3E"/>
        <SolidColorBrush x:Key="BrandSecondary" Color="#4A90A4"/>
    </UserControl.Resources>

    <Grid Padding="20" Background="#F4F6F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="ADDICT MONITOR" FontSize="14" FontWeight="Bold" Foreground="{StaticResource DangerRed}" CharacterSpacing="50"/>
            <TextBlock Text="Flagged Drug-Shopping Candidates" FontSize="26" Foreground="{StaticResource BrandDark}" FontWeight="Bold" Margin="0,5,0,5"/>
            <TextBlock Text="These patients met the criteria for abusive drug acquisition (≥3 same-med prescriptions from different doctors within 30 days)." 
                       FontSize="14" Foreground="#6B7280" TextWrapping="Wrap"/>
        </StackPanel>

        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.AddictCandidates, Mode=OneWay}" SelectionMode="None">
            
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Margin" Value="0,0,0,10"/>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="entity:Patient">
                    <Border Background="White" BorderBrush="{StaticResource DangerRed}" BorderThickness="1,1,1,3" 
                            CornerRadius="8" Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE77B;" Foreground="{StaticResource DangerRed}" FontSize="18"/>
                                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrandDark}">
                                        <Run Text="{x:Bind FirstName}"/> <Run Text="{x:Bind LastName}"/>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="15" Margin="0,10,0,0">
                                    <TextBlock Foreground="#4B5563" FontSize="14">
                                        <Run Text="CNP:" FontWeight="SemiBold"/> <Run Text="{x:Bind Cnp}"/>
                                    </TextBlock>
                                    <TextBlock Foreground="#4B5563" FontSize="14">
                                        <Run Text="Phone:" FontWeight="SemiBold"/> <Run Text="{x:Bind PhoneNo}"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">

                                <Button Content="View History" Background="White" BorderBrush="#CBD5E1" Foreground="#4B5563" Height="40">

                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#F1F5F9"/>
                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#4B5563"/>
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#E2E8F0"/>
                                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#4B5563"/>
                                    </Button.Resources>

                                    <Button.Flyout>
                                        <Flyout>
                                            <Flyout.FlyoutPresenterStyle>
                                                <Style TargetType="FlyoutPresenter">
                                                    <Setter Property="Background" Value="#F8FAFC"/>
                                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Setter Property="CornerRadius" Value="8"/>
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="MaxWidth" Value="600"/>
                                                </Style>
                                            </Flyout.FlyoutPresenterStyle>
                                            
                                            <StackPanel MinWidth="250" Padding="15">
                                                <TextBlock Text="Chronic Conditions:" FontWeight="Bold" Foreground="{StaticResource BrandDark}" Margin="0,0,0,10"/>
                                                
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon Glyph="&#xE946;" FontSize="14" Foreground="{StaticResource DangerRed}" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                                    <TextBlock Text="{x:Bind MedicalHistory.ChronicConditions[0]}" TextWrapping="Wrap" Foreground="#334155" FontSize="13" LineHeight="20"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                                <Button Background="{StaticResource DangerRed}" 
                                        Foreground="White" 
                                        Height="40" 
                                        BorderThickness="0"
                                        Click="OnNotifyPoliceClicked"
                                        CommandParameter="{x:Bind Id}"> 
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#C53030"/>
                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#9B2C2C"/>
                                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                                    </Button.Resources>

                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xEB41;" FontSize="15" VerticalAlignment="Center" Margin="0,1,0,0"/>
                                        <TextBlock Text="Notify Police" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
