<ContentDialog
    x:Class="HospitalManagement.View.PrescriptionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Prescription Details"
    CloseButtonText="Close"
    DefaultButton="Close"
    Width="600">

    <ScrollViewer>
        <StackPanel Spacing="15" Padding="20">
            <!-- Medications List -->
            <StackPanel Spacing="5">
                <TextBlock Text="Medications" Foreground="Gray" FontSize="12" FontWeight="SemiBold"/>
                <ListView x:Name="MedicationsList"
                          SelectionMode="None"
                          Height="Auto"
                          BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#3A4A5A" CornerRadius="6" Padding="12" Margin="0,5,0,0" BorderThickness="1" BorderBrush="#4A5A6A">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding MedName}" 
                                               Foreground="White" FontWeight="SemiBold" FontSize="13" Grid.Column="0"/>
                                    <TextBlock Foreground="LightGray" FontSize="12" Grid.Column="1">
                                        <Run Text="Qty: "/>
                                        <Run Text="{Binding Quantity}"/>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock x:Name="NoMedicationsBlock"
                           Text="No medications prescribed"
                           Foreground="Gray" FontSize="12" Visibility="Collapsed"/>
            </StackPanel>

            <!-- Doctor Notes -->
            <StackPanel Spacing="5">
                <TextBlock Text="Doctor Notes" Foreground="Gray" FontSize="12" FontWeight="SemiBold"/>
                <Border Background="#3A4A5A" CornerRadius="8" Padding="10">
                    <TextBlock x:Name="DoctorNotesBlock" 
                               Foreground="White" TextWrapping="WrapWholeWords" FontSize="13"/>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
